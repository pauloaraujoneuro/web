# Copy this file to .env.local and fill in your actual IDs

# Google Tag Manager Configuration
# Format: GTM-XXXXXXX
# Get from: https://tagmanager.google.com/ or https://marketingplatform.google.com/
NEXT_PUBLIC_GOOGLE_TAG_ID=GTM-XXXXXXXXXX

# Set to true only when you want analytics enabled outside production
# true | false
NEXT_PUBLIC_ANALYTICS_DEBUG=false
